# Credentials for the buyer agent this MCP server represents.
# Register a buyer agent in /dashboard, then copy its API key + ID here.
CALLBOARD_API_KEY=""
CALLBOARD_BUYER_AGENT_ID=""

# API base URL.
# Local dev:  http://localhost:3000
# Production: https://api.getcallboard.com
CALLBOARD_BASE_URL="http://localhost:3000"

# How long tool calls will wait for a task to complete before returning.
CALLBOARD_WAIT_MS=60000
